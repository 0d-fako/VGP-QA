# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your real values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-your-key-here

# ── Azure PostgreSQL (Flexible Server) ────────────────────────────────────────
# Option A: full connection URL (overrides PG* vars below)
# DATABASE_URL=postgres://user:pass@host.postgres.database.azure.com:5432/dbname?sslmode=require
#
# Option B: individual PG* variables (auto-assembled into DATABASE_URL by config.py)
PGHOST=yourserver.postgres.database.azure.com
PGUSER=your_admin
PGPORT=5432
PGDATABASE=postgres
PGPASSWORD=your_password

# ── Azure Blob Storage (optional — local fallback used if empty) ──────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_CONTAINER_NAME=test-evidence

# ── Playwright ────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=30000
MAX_RETRIES=3
SCREENSHOTS_DIR=screenshots

# ── Rate limiting / cost controls ─────────────────────────────────────────────
MAX_REQUIREMENTS=20
MAX_TEST_CASES=10
MAX_API_CALLS_PER_SESSION=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
